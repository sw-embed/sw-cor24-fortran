#!/usr/bin/env bash
# fortran -- compile an FTI-0 .f source to COR24 assembly.
#
# Usage:
#   fortran <input.f>            # writes COR24 assembly to stdout
#   fortran --help
#
# Real FTI-0 compilation. Chains the three SNOBOL4-implemented
# compiler phases on the COR24 emulator:
#
#   input.f -> normalize.sno -> classify.sno -> emit_asm.sno -> .s
#
# Each phase runs as a separate snobol4 invocation; output of phase N
# is loaded at 0x090000 for phase N+1.
#
# End-to-end pipeline:
#
#   scripts/fortran input.f > /tmp/foo.s
#   cor24-asm /tmp/foo.s -o /tmp/foo.lgo
#   cor24-emu --lgo /tmp/foo.lgo --quiet --speed 0
#
# Replaces the earlier Path-A short-circuit which emitted a
# pre-baked examples/hello.s. The compiler now produces real output
# from any .f source within the FTI-0 subset that the phases support.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"

if [ "${1:-}" = "--help" ] || [ "${1:-}" = "-h" ]; then
    sed -n '2,/^$/p' "$0" | sed 's/^# \?//'
    exit 0
fi

if [ $# -lt 1 ]; then
    echo "fortran: error: expected one argument (an .f source file)" >&2
    echo "Usage: fortran <input.f>" >&2
    exit 2
fi

INPUT_F="$1"
if [ ! -f "$INPUT_F" ]; then
    echo "fortran: error: $INPUT_F not found." >&2
    exit 1
fi

if ! command -v snobol4 >/dev/null 2>&1; then
    echo "fortran: error: 'snobol4' wrapper not on PATH." >&2
    echo "  See docs/snobol4-blockers.md and tools/briefs/dcsno-bootstrap-snobol4-toolchain.md." >&2
    exit 2
fi

NORMALIZE="$REPO_DIR/snobol4/src/normalize.sno"
CLASSIFY="$REPO_DIR/snobol4/src/classify.sno"
EMIT_ASM="$REPO_DIR/snobol4/src/emit_asm.sno"
RUNTIME_PUTINT="$REPO_DIR/snobol4/runtime/putint.s"

for f in "$NORMALIZE" "$CLASSIFY" "$EMIT_ASM" "$RUNTIME_PUTINT"; do
    if [ ! -f "$f" ]; then
        echo "fortran: error: compiler phase or runtime missing: $f" >&2
        exit 1
    fi
done

WORK="$(mktemp -d)"
trap 'rm -rf "$WORK"' EXIT

# Phase 1: normalize -- read fixed-form .f, emit normalized statement
# records.
snobol4 --load-binary "$NORMALIZE@0x080000" \
        --load-binary "$INPUT_F@0x090000" \
        --entry 0 --quiet --speed 0 -n 100000000 -t 60 \
        > "$WORK/normalized.txt" 2>/dev/null

# Phase 2: classify -- identify statement kinds.
snobol4 --load-binary "$CLASSIFY@0x080000" \
        --load-binary "$WORK/normalized.txt@0x090000" \
        --entry 0 --quiet --speed 0 -n 100000000 -t 60 \
        > "$WORK/classified.txt" 2>/dev/null

# Phase 3: emit_asm -- emit COR24 assembly.
snobol4 --load-binary "$EMIT_ASM@0x080000" \
        --load-binary "$WORK/classified.txt@0x090000" \
        --entry 0 --quiet --speed 0 -n 100000000 -t 60 \
        > "$WORK/asm-pre-splice.s" 2>/dev/null

# Splice runtime _putint into the emitted .s at the marker line.
# (emit_asm.sno can't emit _putint inline -- it would push the
# SNOBOL4 program past dcsno's static-program-size limit. See
# tools/briefs/dcsno-static-program-size-limit.md.)
awk -v rt="$RUNTIME_PUTINT" '
    /^; __RUNTIME_PUTINT__$/ {
        while ((getline line < rt) > 0) print line
        close(rt)
        next
    }
    { print }
' "$WORK/asm-pre-splice.s"
