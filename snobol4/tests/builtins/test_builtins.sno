*       Verifies that SIZE, SUBSTR, and CHAR are present and correct
*       in the SNOBOL4 interpreter that this project depends on.
*       Mirrors examples/test_builtins.sno in sw-cor24-snobol4 (the
*       upstream verification of issue #1).
        OUTPUT = 'SIZE(HELLO)=' SIZE('HELLO')
        OUTPUT = 'SUBSTR(ABC,1,1)=' SUBSTR('ABC', 1, 1)
        OUTPUT = 'SUBSTR(ABC,2,2)=' SUBSTR('ABC', 2, 2)
        OUTPUT = 'CHAR(39)=' CHAR(39)
        OUTPUT = 'CHAR(65)=' CHAR(65)
        END
