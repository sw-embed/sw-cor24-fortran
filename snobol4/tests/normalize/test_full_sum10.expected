stmt1 line=2 label= text=PROGRAM SUM10
stmt2 line=3 label= text=INTEGER I
stmt3 line=4 label= text=INTEGER S
stmt4 line=5 label= text=S = 0
stmt5 line=6 label= text=DO 100 I = 1, 10
stmt6 line=7 label= text=S = S + I
stmt7 line=8 label=100 text=CONTINUE
stmt8 line=9 label= text=PRINT *, S
stmt9 line=10 label= text=STOP
stmt10 line=11 label= text=END
